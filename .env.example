# Neo4j connection — works with any Neo4j distribution that speaks Bolt
# (local Docker, Neo4j Desktop, AuraDB Free/Pro, self-hosted, cluster, etc.)
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# URI scheme picks the right transport automatically:
#   bolt://       - unencrypted, single instance (local Docker, dev)
#   bolt+s://     - encrypted, single instance
#   neo4j://      - unencrypted, routing (works with cluster or single)
#   neo4j+s://    - encrypted, routing (use this for AuraDB)

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# Optional: truncate input/output text fields per span to keep big LLM
# prompts from blowing up the graph. Default is 2000 chars per field.
# Set to 0 to disable truncation entirely (production at your own risk).
# IO_MAX_CHARS=9999
